# ============================================================================
# .gitignore - FRONTEND (Vue 3 + Vite)
# ============================================================================

# --- Dependências --------------------------------------------------------
node_modules/
.pnp
.pnp.js

# --- Variáveis de ambiente -------------------------------------------------
# Caso o frontend venha a usar variáveis VITE_* sensíveis no futuro
.env
.env.local
.env.*.local
.env.development
.env.production

# --- Build / Output ---------------------------------------------------------
# Pasta gerada pelo "npm run build" - o Vercel gera isso automaticamente
dist/
dist-ssr/
build/
*.local

# --- Logs ----------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Cache do Vite e do TypeScript -------------------------------------------
.vite/
*.tsbuildinfo

# --- Editores / IDE --------------------------------------------------------
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Sistema Operacional -----------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Arquivos temporários ----------------------------------------------------
*.tmp
*.temp

# --- PWA: arquivos gerados automaticamente (se usar plugin de PWA) -----------
dev-dist/


*.json